# Copie ce fichier en `.env` et remplis les clés. Le pipeline fonctionne
# en mode dégradé sans elles (--local + cartes stub à éditer à la main).

# Relais Midjourney (apiframe.ai — clé afk_...).
# ⚠️ Service non officiel : viole les CGU Midjourney, risque de ban du compte MJ.
APIFRAME_API_KEY=

# API Claude pour l'enrichissement stats/nom/lore (console.anthropic.com).
ANTHROPIC_API_KEY=
